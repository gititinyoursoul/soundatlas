# SoundAtlas local environment example
#
# Real secrets must stay outside the repository, for example in:
# C:\Users\Marius\secrets\soundatlas\.env
#
# Point the app to that file by setting SOUNDATLAS_ENV_FILE in your shell.
# Do not create a real .env inside this workspace.

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Media enrichment control
SOUNDATLAS_USE_DUMMY_SERVICES=false
SOUNDATLAS_OPENAI_MODEL=gpt-4.1-mini

# Media enrichment: YouTube
YOUTUBE_API_KEY=

# Media enrichment: OpenAI-compatible analyzer/ranker
SOUNDATLAS_OPENAI_API_KEY=

# Media enrichment: Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Media enrichment: Qobuz
QOBUZ_APP_ID=
QOBUZ_USER_AUTH_TOKEN=
