# SoundAtlas local environment example
#
# Real secrets must stay outside the repository. Point the app to an
# external env file by setting SOUNDATLAS_ENV_FILE in your shell, or pass
# secrets explicitly through Docker Compose overrides or Docker secrets.
# Do not create a real .env inside this workspace.
#
# Devcontainer convention:
#   host:      ../secrets/soundatlas/.env
#   container: /run/secrets/soundatlas.env
#   env var:   SOUNDATLAS_ENV_FILE=/run/secrets/soundatlas.env

# Frontend
VITE_DATA_MODE=api
VITE_API_BASE_URL=http://127.0.0.1:8000

# Frontend when running through Docker Compose
# VITE_API_BASE_URL=http://localhost:8000

# Public static frontend builds
# VITE_DATA_MODE=static
# VITE_BASE_PATH=/soundatlas

# Media enrichment control
SOUNDATLAS_USE_DUMMY_SERVICES=false

# Media enrichment: YouTube
YOUTUBE_API_KEY=

# Media enrichment: Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Media enrichment: Qobuz
QOBUZ_APP_ID=
QOBUZ_USER_AUTH_TOKEN=
