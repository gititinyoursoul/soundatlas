# Dummy-only values for local Codex work and tests.
# Never replace these placeholders with real secrets.
# Real GitHub agent tokens should live outside the repo, for example:
# ../secrets/soundatlas/github-agent.env

SOUNDATLAS_USE_DUMMY_SERVICES=true
SOUNDATLAS_GIT_AUTHOR_NAME=SoundAtlas Dev
SOUNDATLAS_GIT_AUTHOR_EMAIL=soundatlas-dev@example.invalid
GH_TOKEN=dummy-github-agent-token
YOUTUBE_API_KEY=dummy-youtube-key
SPOTIFY_CLIENT_ID=dummy-spotify-client-id
SPOTIFY_CLIENT_SECRET=dummy-spotify-client-secret
QOBUZ_APP_ID=dummy-qobuz-app-id
QOBUZ_USER_AUTH_TOKEN=dummy-qobuz-user-token
